# AWS S3 Configuration for Component Catalog Upload
# catalog:upload スクリプトで使用される環境変数

# S3 バケット名（必須）
AWS_S3_BUCKET=your-bucket-name

# AWS リージョン（オプション、デフォルト: ap-northeast-1）
AWS_REGION=ap-northeast-1

# S3 ベースURL（オプション、デフォルト: https://{AWS_S3_BUCKET}.s3.{AWS_REGION}.amazonaws.com）
# カスタムドメインやCloudFrontを使用する場合はここに設定
S3_BASE_URL=https://your-bucket-name.s3.ap-northeast-1.amazonaws.com

# AWS認証情報
# AWS CLIで設定済みの場合は不要です
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
