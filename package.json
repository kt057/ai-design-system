{
  "name": "@kt057/ai-design-system",
  "version": "0.2.0",
  "description": "AI-friendly React design system built on React Aria Components and Tailwind CSS v4. Ships with a machine-readable component manifest and rule docs so AI agents can use it correctly in any consumer project.",
  "license": "MIT",
  "author": "kichikawa57 <k.ichikawa057@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KT057/ai-design-system.git"
  },
  "keywords": [
    "react",
    "design-system",
    "react-aria",
    "tailwindcss",
    "ai",
    "components",
    "accessibility",
    "headless-ui"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./components.json": "./components.json",
    "./rules/*": "./rules/*"
  },
  "files": [
    "dist",
    "rules",
    "components.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.18.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "pnpm run build:lib && pnpm run build:css && pnpm run build:manifest",
    "build:lib": "tsup",
    "build:css": "tailwindcss -i src/styles/globals.css -o dist/styles.css --minify",
    "build:manifest": "tsx scripts/generate-manifest.ts",
    "build:storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:vrt": "vitest --project=storybook --run",
    "reg-suit:run": "reg-suit run",
    "reg-suit:publish": "reg-suit publish",
    "install:playwright:browser": "npx playwright install --with-deps chromium",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "release": "pnpm run build && changeset publish",
    "prepublishOnly": "pnpm run build",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react-aria-components": "^1.6.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@storycap-testrun/browser": "^2.1.1",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^4.0.0",
    "@vitest/browser-playwright": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^9.1.20",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reg-keygen-git-hash-plugin": "^0.14.5",
    "reg-notify-github-plugin": "^0.14.5",
    "reg-publish-s3-plugin": "^0.14.4",
    "reg-suit": "^0.14.5",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.0.7",
    "vitest": "^4.0.0"
  }
}
